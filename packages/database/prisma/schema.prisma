// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Table des utilisateurs
model User {
  id                  String                @id @default(uuid())
  email               String                @unique
  name                String?
  passwordHash        String                @default("")
  transactions        Transaction[]
  budgetGoals         BudgetGoal[]
  recurringTransactions RecurringTransaction[]
  budgetAlerts        BudgetAlert[]
  createdAt           DateTime              @default(now())
}

// Table des transactions (Dépenses / Revenus)
model Transaction {
  id       String   @id @default(uuid())
  label    String
  amount   Float
  currency String   @default("EUR")
  category String?
  type     String   @default("expense") // "expense" or "income"
  date     DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  createdAt DateTime @default(now())
}

// Budget Goals - Track spending limits by category
model BudgetGoal {
  id        String   @id @default(uuid())
  category  String
  limitAmount Float
  currency  String   @default("EUR")
  period    String   @default("monthly") // "monthly", "weekly", "yearly"
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([userId, category, period])
}

// Recurring Transactions - Auto-create transactions
model RecurringTransaction {
  id              String   @id @default(uuid())
  label           String
  amount          Float
  currency        String   @default("EUR")
  category        String?
  type            String   @default("expense") // "expense" or "income"
  frequency       String   // "weekly", "biweekly", "monthly", "quarterly", "yearly"
  startDate       DateTime
  endDate         DateTime?
  lastGeneratedAt DateTime?
  isActive        Boolean  @default(true)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Budget Alerts - Notifications
model BudgetAlert {
  id          String   @id @default(uuid())
  category    String
  message     String
  type        String   // "warning", "critical"
  currentAmount Float
  limitAmount Float
  threshold   Int      @default(80) // Alert at 80% of limit
  isRead      Boolean  @default(false)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  createdAt   DateTime @default(now())
}
