{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "bun install --frozen-lockfile",
  "buildCommand": "bun run build",
  "devCommand": "bun run dev",
  "bunVersion": "1.3.11",
  "rewrites": [
    {
      "source": "/backend/:path*",
      "destination": "https://api.ton-domaine.com/:path*"
    }
  ]
}
