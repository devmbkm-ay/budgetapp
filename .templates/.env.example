# ============================================================
# TEMPLATE: .env (Environment variables for docker-compose)
# Copy this file as `.env` and update values for your project
# ============================================================

# Database Configuration
DB_USER=postgres
DB_PASSWORD=mysecretpassword
DB_NAME=app_db
DB_PORT=5432

# API Configuration
API_PORT=3001
API_URL=http://localhost:3001

# Web Configuration
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Node Environment
NODE_ENV=production

# Feature Flags (if applicable)
DEBUG=false
