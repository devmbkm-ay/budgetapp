{
  "name": "budgetapp",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "bun run dev:full",
    "dev:app": "turbo run dev --filter=api --filter=web -- --webpack",
    "dev:full": "bun run scripts/dev-full.ts",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "prettier": "^3.7.4",
    "turbo": "^2.9.3",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
